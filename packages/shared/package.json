{
  "name": "@domino-poker/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run build -w @domino-poker/core && tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "typecheck:build-boundary": "npm run build -w @domino-poker/core && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@domino-poker/core": "1.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
