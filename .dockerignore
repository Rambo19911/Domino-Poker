# Docker build konteksts (lieto ar deploy/Dockerfile no repo saknes).
# Neiekļaut: mazāks, ātrāks, tīrāks attēls.
node_modules
**/node_modules
**/dist
.git
data/*.sqlite
data/*.sqlite-wal
data/*.sqlite-shm
.env
.env.*
!.env.example
**/*.tsbuildinfo
.turbo
.cache
.local-server
# Web būves izvade — serveris (core → shared → server) to nelieto, tāpēc tā ~96 MB
# cache nedrīkst nonākt servera attēlā.
**/.next
# Lokāli aģentu/rīku/izstrādes katalogi, kas nav vajadzīgi izpildlaikā.
.remember/
.claude/
.playwright-mcp/
logs/
test-results/
