# Caddy reverse proxy paraugs Domino Poker (Fāze 12.2) — vienkāršāka alternatīva Nginx.
# Caddy automātiski iegūst un atjauno TLS sertifikātus (Let's Encrypt) un automātiski
# apstrādā WebSocket upgrade — nav jāraksta upgrade galvenes manuāli.
#
# Uzstādīšana:
#   sudo cp deploy/Caddyfile.example /etc/caddy/Caddyfile
#   # pielāgo domēnu, tad: sudo systemctl reload caddy

tavs-domens.lv {
    # Multiplayer WebSocket: /ws -> MP serveris (Caddy upgrade automātiski).
    reverse_proxy /ws* 127.0.0.1:4000

    # Opcionālā autentifikācija + paroles atjaunošana: /auth/* -> MP serveris.
    # (Klients atvasina HTTP bāzi no WS URL, tāpēc /auth iet uz to pašu domēnu.)
    # SVARĪGI: serveris rate-limito pēc IP un ar TRUST_PROXY=true uzticas
    # X-Forwarded-For. `header_up` PĀRRAKSTA XFF ar īsto klienta IP, lai klients
    # nevar to viltot (Caddy pēc noklusējuma PIEVIENO, tāpēc bez šī kreisā vērtība
    # būtu klienta kontrolēta un per-IP limits — apejams).
    reverse_proxy /auth/* 127.0.0.1:4000 {
        header_up X-Forwarded-For {http.request.remote.host}
    }

    # MP lobby čata tulkošana: /chat/* -> MP serveris (Google Cloud Translation).
    # Klients sūta POST /chat/translate; Google credentials paliek TIKAI serverī.
    # Maršruts vajadzīgs tikai tad, ja TRANSLATE_ENABLED=true (citādi serveris šo
    # ceļu nereģistrē un atbild 404 — nekaitīgi). Tāda pati XFF pārrakstīšana kā /auth.
    reverse_proxy /chat/* 127.0.0.1:4000 {
        header_up X-Forwarded-For {http.request.remote.host}
    }

    # About paneļa kontaktforma: POST /contact -> MP serveris (Resend e-pasts).
    # Maršruts vajadzīgs tikai tad, ja serverim ir e-pasta senderis (RESEND_API_KEY +
    # EMAIL_FROM); citādi serveris atbild 404 — nekaitīgi. Tāda pati XFF pārrakstīšana
    # kā /auth (serveris rate-limito kontaktformu pēc IP).
    reverse_proxy /contact 127.0.0.1:4000 {
        header_up X-Forwarded-For {http.request.remote.host}
    }

    # Veikals (kosmētika/tēmas): /store/* -> MP serveris (POST /store/buy, GET /store/owned).
    # Auth obligāts; serveris rate-limito pēc IP. BEZ šī kārtulas tēmu pirkšana 404 prodā.
    # Tāda pati XFF pārrakstīšana kā /auth.
    reverse_proxy /store* 127.0.0.1:4000 {
        header_up X-Forwarded-For {http.request.remote.host}
    }

    # (pēc izvēles) metrikas tikai lokāli:
    # @metrics path /metrics
    # respond @metrics 403

    # Viss pārējais -> web klients (Next.js).
    reverse_proxy 127.0.0.1:3000
}
