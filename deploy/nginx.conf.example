# Nginx reverse proxy paraugs Domino Poker (Fāze 12.2).
# Maršrutē vienu publisku domēnu uz diviem iekšējiem servisiem:
#   /       -> web klients (Next.js, 127.0.0.1:3000)
#   /ws     -> multiplayer serveris (WebSocket, 127.0.0.1:4000)
#   /auth/  -> multiplayer serveris (auth + paroles atjaunošana, 127.0.0.1:4000)
# Pielāgo `server_name` un sertifikātu ceļus (parasti no certbot / Let's Encrypt).
#
# Uzstādīšana (Ubuntu/Debian):
#   sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/domino-poker
#   sudo ln -s /etc/nginx/sites-available/domino-poker /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   # TLS: sudo certbot --nginx -d tavs-domens.lv

# WebSocket upgrade palīgs. ŠIM jābūt http{} kontekstā (piem. /etc/nginx/nginx.conf
# vai atsevišķā /etc/nginx/conf.d/ws_upgrade.conf failā), NE server{} iekšā.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# 1) HTTP -> HTTPS pāradresācija.
server {
    listen 80;
    server_name tavs-domens.lv;
    return 301 https://$host$request_uri;
}

# 2) HTTPS — galvenais serveris.
server {
    listen 443 ssl http2;
    server_name tavs-domens.lv;

    # TLS sertifikāti (certbot tos parasti aizpilda automātiski).
    ssl_certificate     /etc/letsencrypt/live/tavs-domens.lv/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tavs-domens.lv/privkey.pem;

    # --- Multiplayer WebSocket: /ws -> MP serveris ---
    location /ws {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        # Šie divi pārvērš savienojumu par WebSocket (upgrade).
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # WS savienojumi ir ilgi — neaizver tos pēc īsa klusuma (serveris pats
        # uztur heartbeat/PING; 1h dod rezervi).
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # --- Auth + paroles atjaunošana: /auth/* -> MP serveris (NE Next.js) ---
    # Klients atvasina HTTP bāzi no WS URL, tāpēc /auth iet uz to pašu domēnu.
    # SVARĪGI: serveris rate-limito pēc IP. Lai tas redzētu īsto klienta IP (nevis
    # 127.0.0.1), serverim jāuzstāda TRUST_PROXY=true — tikai tad XFF tiek uzticēts.
    location /auth/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # --- MP lobby čata tulkošana: /chat/* -> MP serveris (NE Next.js) ---
    # Klients sūta POST /chat/translate; Google credentials paliek TIKAI serverī.
    # Vajadzīgs tikai ar TRANSLATE_ENABLED=true; citādi serveris šo ceļu nereģistrē.
    location /chat/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # --- (pēc izvēles) veselības/metriku gala punkti tikai iekšējai uzraudzībai ---
    # Komentē ārā, ja negribi tos publiski. Drošāk: ierobežot ar `allow`/`deny`.
    # location = /health  { proxy_pass http://127.0.0.1:4000; }
    # location = /metrics { allow 127.0.0.1; deny all; proxy_pass http://127.0.0.1:4000; }

    # --- Web klients: viss pārējais -> Next.js ---
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Next.js HMR/iebūvētie WS (dev) — nekaitīgi arī produkcijā.
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}
