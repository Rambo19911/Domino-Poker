    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.1",
    "@types/pg": "8.20.0",
    "@types/ws": "^8.18.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
