# Domino Poker — multiplayer servera konfigurācija (paraugs).
# Nokopē šo failu uz `.env` un pielāgo. `.env` NETIEK commitots (sk. .gitignore).
# Serveris lasa `.env` no darba mapes (repo sakne, kad palaiž `node apps/server/dist/index.js`).

# --- Tīkls ---
# HTTP un WebSocket klausīšanās ports (WS dalās ar šo portu, decision B).
# SERVER_PORT ir galvenais nosaukums; HTTP_PORT der kā alias.
SERVER_PORT=4000

# Adrese, uz kuras serveris klausās.
#   0.0.0.0  = visi tīkla interfeisi (ērti tiešai testēšanai uz VPS).
#   127.0.0.1 = tikai lokāli — IETEICAMS produkcijā AIZ reverse proxy (Nginx/Caddy),
#               lai serveri nevar sasniegt tieši no interneta.
SERVER_HOST=0.0.0.0

# --- Datubāze ---
# Lokāli: SQLite faila ceļš (noklusējums) vai `:memory:` (tikai testiem).
DATABASE_URL=./data/dev.sqlite
# VPS/kopīgai DB: PostgreSQL URL (izmanto `PostgresStorage` adapteri), piem.:
# DATABASE_URL=postgres://user:parole@localhost:5432/domino

# --- PostgreSQL pool limiti (tikai PG režīmā; SQLite tos ignorē) ---
# UZMANĪBU: serverim ir DIVI pool (storage + event bus) + 1 LISTEN klients, tāpēc
# kopējie savienojumi pret DB ≈ 2 × PG_POOL_MAX + 1. Saskaņo ar PostgreSQL
# `max_connections` un citiem klientiem (čaulas, backup, citas lietotnes).
# Maks. savienojumu skaits VIENĀ pool (noklusējums 10).
# PG_POOL_MAX=10
# Dīkstāves savienojuma aizvēršana ms; 0 = neaizvērt (noklusējums 10000).
# PG_POOL_IDLE_TIMEOUT_MS=10000
# Cik ilgi gaidīt brīvu savienojumu ms; 0 = bez taimauta (noklusējums 0).
# Produkcijā ieteicams iestatīt (piem. 5000), lai pieprasījumi neiestrēgst pie DB pārslodzes.
# PG_POOL_CONNECTION_TIMEOUT_MS=0

# --- Spēle ---
# Turna ilgums (ms) — solīšanas/gājiena countdown. Noklusējums 10000 (10 s).
# Diapazons [100, 600000]. Testēšanai var iestatīt īsāku (piem. 5000), lai partijas
# rit ātrāk. NEIETEKMĒ kauliņu maisīšanu/izdali (tās atkarīgas tikai no seed).
TURN_DURATION_MS=10000

# --- Operacionālie parametri (noklusējumi = līdzšinējā uzvedība; parasti NAV jāmaina) ---
# Pirms-spēles atskaite (ms) uz galda pirms solīšanas sākuma; 0 = bez atskaites.
# PRE_GAME_DELAY_MS=10000
# Aizture (ms) starp botu gājieniem (secīga izspēle); 0 = bez aiztures.
# BOT_PACE_MS=800
# Pauze (ms) pēc pabeigta trika, pirms turpinās nākamais gājiens.
# UZMANĪBU: jābūt ≥ 1500 (web klients aiztur pabeigto triku 1500 ms — mazāka
# vērtība tiek noraidīta startā, lai nākamais gājiens neielaužas aizturē).
# TRICK_PAUSE_MS=1700
# Grace (ms) pēc atvienošanās pirms auto-forfeit / istabas iznīcināšanas.
# ABANDON_GRACE_MS=60000
# LOBBY_STATE broadcastu koalescēšanas logs (ms); 0 = sūtīt tūlīt (bez debounce).
# LOBBY_STATE_DEBOUNCE_MS=200
# Cik lobby čata ziņas paturēt atmiņā / ielādēt no DB startā (≥1).
# CHAT_HISTORY_LIMIT=50

# --- MP lobby chat translation (Google Cloud Translation API, server-side) ---
# Enable only after Cloud Translation API is active and the server can read the
# service account JSON file. Never store that JSON file in this repository.
# TRANSLATE_ENABLED=true
# GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/etc/domino-poker/google-translate.json
# Advanced v3 default location. For regular text translation, global is enough.
# TRANSLATE_LOCATION=global
# Free NMT text tier: first 500,000 characters/month. The daily default is a
# conservative 16,000 chars so steady usage stays inside that monthly free tier.
# TRANSLATE_DAILY_CHAR_LIMIT=16000
# TRANSLATE_MONTHLY_CHAR_LIMIT=500000
# TRANSLATE_RATE_LIMIT_PER_MINUTE=30
# TRANSLATE_CACHE_MAX_ENTRIES=1000
# Istabas īpašumtiesību nomas TTL (ms) — tikai PostgreSQL (multi-instance) režīmā.
# ROOM_LEASE_TTL_MS=30000

# --- E-pasts (paroles atjaunošana + kontaktforma; Resend HTTP API) ---
# Paroles atjaunošana un About paneļa kontaktforma sūta e-pastu caur Resend.
# Bez RESEND_API_KEY + EMAIL_FROM produkcijā abas funkcijas ir ATSPĒJOTAS (serveris
# nekad neizliekas, ka e-pasts nosūtīts). Glabā API atslēgu TIKAI šeit, ne repo.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Sūtītāja adrese — jābūt Resend verificētā domēnā.
# EMAIL_FROM=no-reply@domino-poker.com
# Web bāzes URL paroles atjaunošanas linkam (noklusējums dev web izcelsme).
# APP_BASE_URL=https://domino-poker.com
# Kontaktformas saņēmējs (noklusējums īpašnieka adrese, ja neuzstāda).
# CONTACT_EMAIL=rihardslaskovs@gmail.com

# --- Vide ---
# `development` (noklusējums) vai `production`.
NODE_ENV=production

# --- Drošība / reverse proxy ---
# Vai uzticēties `X-Forwarded-For` headerim auth rate-limit IP atvasināšanai.
# Noklusējums `false` (IP = tiešā savienojuma adrese, nefalsificējams).
# Ieslēdz (`true`) TIKAI tad, ja serveris ir AIZ uzticama reverse proxy (Caddy/Nginx),
# kas pārraksta XFF — citādi klients var falsificēt XFF un apiet rate-limit.
# TRUST_PROXY=true

# --- Atkļūdošana (opt-in) ---
# MP darbību logošana: KATRA komanda + rezultāts uz konsoli un `logs/` failu.
# Pēc noklusējuma IZSLĒGTS (sinhrons disk-write ir spēles komandu ceļā; ieslēgts
# radītu latenci un rakstītu `playerId` žurnālos). Ieslēdz atkļūdošanai ar `1`.
# MP_ACTION_LOG=1
# Log failu mape (noklusējums `logs/` servisa darba mapē).
# MP_ACTION_LOG_DIR=logs
