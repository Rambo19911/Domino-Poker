# Hard-fail install on an unsupported Node version (engines.node >= 22.5.0): the
# server uses the built-in `node:sqlite`, which only exists on Node >= 22.5. Without
# this, `npm install`/`npm ci` succeed on older Node and the server crashes only at
# runtime when importing `node:sqlite` (M12). All dependencies support Node >= 18,
# well below 22.5, so this gate never false-positives on a supported Node.
engine-strict=true

# Neizdrukāt audit kopsavilkumu `npm install`/`npm ci` laikā. Pašreizējās atzīmes
# (vite caur vitest, postcss caur next) ir tikai izstrādes/būves rīkos — neskar
# produkcijas izpildlaiku. Šis NEKO nemaina atkarībās/build; var atcelt, izņemot rindu.
# Manuāli joprojām var pārbaudīt ar `npm audit`.
audit=false
