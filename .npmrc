# Hard-fail install on an unsupported Node version (engines.node >= 24.0.0, .nvmrc pin 24):
# the server uses the built-in `node:sqlite` (needs Node >= 22.5) and `geoip-lite` (needs
# Node >= 24). Without this, `npm install`/`npm ci` succeed on older Node and then fail only
# at runtime/import time. The repo standardized on Node 24 (`.nvmrc`, CI `node-version-file`),
# so this gate matches the actually supported Node and never false-positives.
engine-strict=true
